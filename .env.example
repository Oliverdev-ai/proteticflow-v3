# ProteticFlow v3 — Variáveis de Ambiente
# Copie para .env. NUNCA commite o .env.

# Banco de Dados
DATABASE_URL=postgresql://proteticflow:password@localhost:5432/proteticflow

# Redis
REDIS_URL=redis://localhost:6379

# Autenticação
JWT_SECRET=gere-uma-chave-aleatoria-com-openssl-rand-base64-64
SETTINGS_SECRET_KEY=gere-uma-chave-aleatoria-com-openssl-rand-base64-64
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Servidor
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# Storage S3-compatible
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=proteticflow-dev
S3_REGION=us-east-1

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@proteticflow.com.br

# IA / LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Push Notifications VAPID
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@proteticflow.com.br

# Fiscal
BOLETO_API_KEY=
BOLETO_API_URL=
NFSE_API_KEY=
NFSE_API_URL=
NFSE_ENVIRONMENT=sandbox

# Observabilidade
SENTRY_DSN=
LOG_LEVEL=info
