# ProteticFlow v3 - Variaveis de Ambiente
# Copie para .env. NUNCA commite o .env.

# Servidor
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Banco de Dados
DATABASE_URL=postgresql://proteticflow:password@localhost:5432/proteticflow

# Redis
REDIS_URL=redis://localhost:6379

# Autenticacao
JWT_SECRET=gere-uma-chave-aleatoria-com-openssl-rand-base64-64
JWT_EXPIRES_IN=15m
SETTINGS_SECRET_KEY=gere-uma-chave-aleatoria-com-openssl-rand-base64-64

# Storage MinIO/S3 compatible
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_BUCKET=proteticflow
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false

# Notificacoes
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@proteticflow.com.br

# Integracoes opcionais (fases futuras)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PUBLISHABLE_KEY=
ASAAS_API_KEY=
ASAAS_SANDBOX=true
FOCUS_NFE_TOKEN=
FOCUS_NFE_SANDBOX=true
SENTRY_DSN=
LOG_LEVEL=info
BACKUP_S3_BUCKET=proteticflow-backups
