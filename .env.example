# ProteticFlow v3 - Variaveis de Ambiente
# Copie para .env. NUNCA commite o .env.

# Servidor
NODE_ENV=development
# Se 3001 estiver ocupada (ex.: Grafana), altere para 3002.
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Banco de Dados
# Deve bater com POSTGRES_USER/PASSWORD/DB do docker-compose.dev.yml
DATABASE_URL=postgresql://proteticflow:proteticflow_dev@127.0.0.1:5432/proteticflow_dev

# Redis
REDIS_URL=redis://127.0.0.1:6379
BULLMQ_CONCURRENCY=10
BULLMQ_STALLED_INTERVAL=30000

# Autenticacao
# IMPORTANTE: rode "pnpm local:setup" para gerar valores seguros automaticamente
JWT_SECRET=GERAR_COM_pnpm_local_setup
JWT_EXPIRES_IN=15m
SETTINGS_SECRET_KEY=GERAR_COM_pnpm_local_setup

# Storage MinIO/S3 compatible
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_BUCKET=proteticflow
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false

# Notificacoes
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@proteticflow.com.br
WHATSAPP_PROVIDER=mock
BLIP_API_TOKEN=
BLIP_FROM_NUMBER=
BLIP_BASE_URL=https://http.msging.net

# Integracoes opcionais (fases futuras)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GCP_TTS_API_KEY=
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PUBLISHABLE_KEY=
ASAAS_API_KEY=
ASAAS_SANDBOX=true
FOCUS_NFE_TOKEN=
FOCUS_NFE_SANDBOX=true
SENTRY_DSN=
LOG_LEVEL=info
BACKUP_S3_BUCKET=proteticflow-backups
