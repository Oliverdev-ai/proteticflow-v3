{
  "name": "proteticflow-v3",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "ds:check": "node scripts/ds-grep-check.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "session:check": "cmd /c scripts\\session-check.cmd",
    "local:setup": "docker compose -f docker/docker-compose.dev.yml up -d && tsx scripts/setup-local.ts",
    "local:up": "docker compose -f docker/docker-compose.dev.yml up -d && pnpm dev",
    "local:stop": "docker compose -f docker/docker-compose.dev.yml stop"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=11.10.0 <12"
  },
  "packageManager": "pnpm@11.10.0"
}
