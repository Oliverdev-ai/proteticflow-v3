{
  "name": "@proteticflow/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./trpc": "./src/trpc/router.ts"
  },
  "typesVersions": {
    "*": {
      "trpc": [
        "./src/trpc/router.ts"
      ]
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "check:tenant-isolation": "tsx ../../scripts/check-tenant-isolation.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@proteticflow/shared": "workspace:*",
    "@trpc/server": "^11.0.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.36.0",
    "express": "^5.0.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "otplib": "^13.4.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^2.0.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.0.0",
    "typescript": "*",
    "vitest": "^2.0.0"
  }
}
